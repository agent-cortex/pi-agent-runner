NODE_ENV=production
TZ=Asia/Kolkata
PORT=8787
CALLBACK_PORT=9999
REDIS_URL=redis://redis:6379
RUNNER_API_TOKEN=change-me
WEBHOOK_SECRET=change-me
CALLBACK_URL=http://callback-relay:9999/callback
CRYPTO_BRIEF_CRON=0 9 * * *
CRYPTO_MAX_ITEMS=5
WORKER_CONCURRENCY=2
CALLBACK_ATTEMPTS=3
CALLBACK_RETRY_MS=3000
DATA_DIR=/app/data/artifacts

# Optional telegram relay from callback-relay:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
