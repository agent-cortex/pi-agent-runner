{
  "name": "pi-agent-runner",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Delegate long-running agent tasks to a Raspberry Pi with signed webhook callbacks",
  "scripts": {
    "start:api": "node apps/api/src/index.js",
    "start:worker": "node apps/worker/src/index.js",
    "start:scheduler": "node apps/scheduler/src/index.js",
    "start:installer": "node apps/installer/src/index.js",
    "dev": "echo 'Run services separately: npm run start:api | start:worker | start:scheduler | start:installer'",
    "start:callback-relay": "node apps/callback-relay/src/index.js"
  },
  "dependencies": {
    "bullmq": "^5.58.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "ioredis": "^5.8.1",
    "node-cron": "^4.2.1",
    "rss-parser": "^3.13.0",
    "zod": "^4.1.11"
  }
}
